# Offer 捕手 - 环境变量配置
# 复制此文件为 .env 并填入真实值

# ========== 默认模型配置 ==========
# 可选值: doubao / qwen / kimi / openai / ollama
LLM_MODEL=kimi

# ========== 豆包API配置 ==========
# 获取方式: https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# ========== 通义千问API配置 ==========
# 获取方式: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== Kimi API配置 ==========
# 获取方式: https://platform.moonshot.cn
KIMI_API_KEY=your_kimi_api_key_here
KIMI_API_BASE=https://api.moonshot.cn/v1

# ========== OpenAI API配置 ==========
OPENAI_API_KEY=your_openai_api_key_here

# ========== Ollama本地配置 ==========
# 本地部署无需API_KEY
OLLAMA_API_BASE=http://localhost:11434/v1

# ========== 账号与鉴权 ==========
# JWT 签名密钥，部署时请改成足够随机的长字符串
JWT_SECRET=dev-please-change-this-secret-0xOfferCatcher
# 普通用户凭验证码登录赠送的可用次数（一次完整流程）
FREE_QUOTA_ON_SIGNUP=1
# 站长本人手机号（无限次）
OWNER_PHONE=18303891187
# 通用验证码（任何人凭它登录可体验一次）
VERIFY_CODE=WASD
